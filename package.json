{
  "name": "issuehub",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --project=chromium --grep-invert '@skip-ci'",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\" --ignore-path .prettierignore",
    "deps:check": "npx depcheck --ignores=\"@tailwindcss/postcss,tailwindcss,@types/react-dom\""
  },
  "dependencies": {
    "@emotion/cache": "11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.10",
    "@mui/material": "^7.3.10",
    "@mui/material-nextjs": "7.3.10",
    "@octokit/core": "^7.0.6",
    "@tanstack/react-query": "^5.100.9",
    "next": "16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "16.2.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "6.0.1",
    "depcheck": "^1.4.7",
    "eslint": "^10",
    "eslint-config-next": "16.2.4",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "jsdom": "29.1.1",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "typescript": "^6",
    "typescript-eslint": "8.59.2",
    "vitest": "4.1.5"
  }
}
